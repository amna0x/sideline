{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git show)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git fetch)",
      "Bash(git fetch:*)",
      "Bash(git pull)",
      "Bash(git pull:*)",
      "Bash(git stash list)",
      "Bash(git stash show:*)",
      "Bash(git remote -v)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git blame:*)",
      "Bash(npm --prefix client run build)",
      "Bash(npm --prefix client run dev)",
      "Bash(npm --prefix server run dev)",
      "Bash(npm --prefix server run simulate)",
      "Bash(npm --prefix server run seed)",
      "Bash(npm install:*)",
      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(npm --prefix client test)",
      "Bash(npm --prefix server test)",
      "Bash(npm run:*)",
      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(cat package.json)",
      "Bash(pwd)",
      "Read(./**)",
      "Glob(./**)",
      "Grep(./**)"
    ],
    "deny": [
      "Bash(git push origin master)",
      "Bash(git push origin master:*)",
      "Bash(git push origin main)",
      "Bash(git push origin main:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push:* --force)",
      "Bash(git push:* -f)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout master)",
      "Bash(git commit:* --no-verify)",
      "Bash(git commit:* -n)",
      "Bash(rm -rf:*)",
      "Bash(rm -rf /)",
      "Read(./.env)",
      "Read(./client/.env)",
      "Read(./server/.env)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/id_rsa)",
      "Read(./**/id_ed25519)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout:*)",
      "Bash(git reset:*)",
      "Bash(git revert:*)",
      "Bash(git tag:*)",
      "Bash(npm publish:*)",
      "Bash(npm install -g:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Write(./server/db/schema.sql)",
      "Write(./.gitignore)",
      "Write(./.env.example)"
    ]
  },
  "env": {
    "DISABLE_TELEMETRY": "0"
  }
}
