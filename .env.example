# Copy to client/.env and server/.env, fill in real values.

# ----- Server -----
PORT=4000
CORS_ORIGIN=http://localhost:5173

# AWS Cognito (server-side JWT verification)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=YOUR_APP_CLIENT_ID
COGNITO_TOKEN_USE=id   # 'id' or 'access' — must match what the client sends

# AI / live data
GEMINI_API_KEY=
API_FOOTBALL_API_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io

# HTML-to-image (htmlcsstoimage.com) — used by POST /api/share/card
HCTI_USER_ID=
HCTI_API_KEY=

# Optional: legacy DB (only set if you want a Postgres backend; otherwise the
# in-memory fallback is used)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Client (Vite — must be prefixed VITE_) -----
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=YOUR_APP_CLIENT_ID
