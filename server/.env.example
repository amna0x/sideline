PORT=4000
CORS_ORIGIN=http://localhost:5173

# AWS Cognito (required for production auth; missing values → guest-only mode)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=YOUR_APP_CLIENT_ID
COGNITO_TOKEN_USE=id

# AI / live data
GEMINI_API_KEY=
API_FOOTBALL_API_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io

# Shareable cards via htmlcsstoimage.com
HCTI_USER_ID=
HCTI_API_KEY=

# Optional Postgres-as-a-service (Supabase). When unset, the server uses an
# in-memory store backed by simulator JSON.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
