PORT=4000
CORS_ORIGIN=http://localhost:5173

# AWS Cognito (required for auth; missing values → guest-only mode)
COGNITO_USER_POOL_ID=eu-north-1_XXXXXXXXX
COGNITO_CLIENT_ID=YOUR_APP_CLIENT_ID
COGNITO_TOKEN_USE=id

# AWS RDS PostgreSQL (when DB_HOST is set, the server uses RDS — otherwise in-memory)
DB_HOST=
DB_PORT=5432
DB_NAME=sideline
DB_USER=sideline_app
DB_PASSWORD=

# AWS S3 (optional — for avatar uploads; falls back to data-URL when unset)
AWS_REGION=eu-north-1
S3_BUCKET=

# AI / live data
GEMINI_API_KEY=
API_FOOTBALL_API_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io

# Shareable cards via htmlcsstoimage.com
HCTI_USER_ID=
HCTI_API_KEY=
